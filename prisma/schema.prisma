generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Parent {
  id              String   @id @default(uuid())
  phoneNumber     String   @unique
  password        String
  firstName       String
  lastName        String
  createdAt       DateTime @default(now())
  children        Child[]
}

model Child {
  id        String   @id @default(uuid()) 
  firstName String 
  lastName  String
  dob       DateTime 
  createdAt DateTime @default(now())
  parent    Parent? @relation(fields: [parentId], references: [id])  
  parentId  String
}